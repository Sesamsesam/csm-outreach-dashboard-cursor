# Personal data - never commit
csm_jobs.csv
seen_job_ids.txt
user_profile.txt

# Live search targeting (the user's current knob settings). Gitignored so personal
# targeting never ships; a fresh clone falls back to search_config.example.json (CSM).
search_config.json
cover_letters/*.txt
cover_letters/*.md

# Per-machine setup marker - written after a successful local setup so a later
# session skips setup instead of re-running it. Must stay gitignored: a fresh
# clone should NOT inherit an "already set up" flag.
setup_complete.json

# API keys
dashboard/.hunter_key
dashboard/.apollo_key

# Python
__pycache__/
*.pyc
*.pyo

# macOS
.DS_Store

# Stray skill bundles (the .cursor/skills/ folders are the source of truth;
# this project does not use .skill bundles)
*.skill

# Cursor local/personal settings (the committed .cursor/mcp.json is shared)
.cursor/settings.local.json

# Playwright MCP runtime artifacts: page snapshots (*.yml) and captured browser
# console logs (*.log). The MCP server writes these every run to .playwright-mcp/
# in the project root. They are pure noise (console output from the sites being
# browsed - LinkedIn/Google warnings, tracking-pixel errors, etc.), can balloon to
# thousands of lines while the browser is open, and have no value to commit.
.playwright-mcp/
